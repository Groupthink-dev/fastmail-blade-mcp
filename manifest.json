{
  "name": "fastmail-blade-mcp",
  "version": "0.1.0",
  "description": "Fastmail JMAP MCP Server — email, masked email, and push notifications",
  "author": "Piers",
  "license": "MIT",
  "runtime": "python",
  "entry_point": "fastmail-blade-mcp",
  "environment_variables": {
    "FASTMAIL_API_TOKEN": "Fastmail API token (required)",
    "FASTMAIL_WRITE_ENABLED": "Enable write operations (default: false)",
    "FASTMAIL_MCP_TRANSPORT": "stdio|http (default: stdio)",
    "FASTMAIL_MCP_HOST": "HTTP bind host (default: 127.0.0.1)",
    "FASTMAIL_MCP_PORT": "HTTP bind port (default: 8767)",
    "FASTMAIL_MCP_API_TOKEN": "Bearer token for HTTP auth (disabled if empty)"
  },
  "tools": [
    "fastmail_info",
    "fastmail_identities",
    "mail_mailboxes",
    "mail_read",
    "mail_search",
    "mail_threads",
    "mail_snippets",
    "mail_send",
    "mail_reply",
    "mail_move",
    "mail_flag",
    "mail_delete",
    "mail_bulk",
    "masked_list",
    "masked_create",
    "masked_update",
    "push_subscribe",
    "push_status"
  ]
}
