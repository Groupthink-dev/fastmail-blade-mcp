# Fastmail API token (required)
# Generate at: https://app.fastmail.com/settings/security/tokens
# Scopes needed: urn:ietf:params:jmap:mail, https://www.fastmail.com/dev/maskedemail
FASTMAIL_API_TOKEN=fmu1-xxxxxxxx

# Write protection (default: false)
# Set to "true" to enable send, reply, move, flag, delete, bulk, masked_create, masked_update
FASTMAIL_WRITE_ENABLED=false

# Transport (default: stdio)
FASTMAIL_MCP_TRANSPORT=stdio
FASTMAIL_MCP_HOST=127.0.0.1
FASTMAIL_MCP_PORT=8767

# Bearer token for HTTP transport auth (disabled if empty)
FASTMAIL_MCP_API_TOKEN=
